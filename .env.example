# 和风天气 API 配置
QW_API_HOST=your-api-host.re.qweatherapi.com
QW_API_KEY=your_api_key_here
QW_KEY_ID=your_key_id
QW_PROJECT_ID=your_project_id
QW_PRIVATE_KEY_FILE=/path/to/ed25519-private.pem

# 或者直接写私钥内容（不推荐长期放在环境变量）
# QW_PRIVATE_KEY_TEXT=-----BEGIN OPENSSH PRIVATE KEY-----

# 服务配置
PORT=8787
JWT_EXPIRE_SECONDS=900
HTTP_TIMEOUT=20
